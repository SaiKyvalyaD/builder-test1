{
  "root": "contact-form",
  "elements": {
    "contact-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 16
      },
      "children": [
        "name-label",
        "name-input",
        "email-label",
        "email-input",
        "message-label",
        "message-input",
        "submit-button"
      ]
    },
    "name-label": {
      "type": "Label",
      "props": {
        "content": "Name"
      },
      "children": []
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your name",
        "type": "text",
        "value": {
          "$bindState": "/form/name"
        }
      },
      "children": []
    },
    "email-label": {
      "type": "Label",
      "props": {
        "content": "Email"
      },
      "children": []
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email",
        "value": {
          "$bindState": "/form/email"
        }
      },
      "children": []
    },
    "message-label": {
      "type": "Label",
      "props": {
        "content": "Message"
      },
      "children": []
    },
    "message-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your message",
        "type": "text",
        "value": {
          "$bindState": "/form/message"
        }
      },
      "children": []
    },
    "submit-button": {
      "type": "Button",
      "props": {
        "label": "Submit"
      },
      "on": {
        "press": {
          "action": "setState",
          "params": {
            "statePath": "/form/submitted",
            "value": true
          }
        }
      },
      "children": []
    }
  }
}