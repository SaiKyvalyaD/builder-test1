{
  "root": "contact-form",
  "elements": {
    "contact-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 10
      },
      "children": [
        "name-label",
        "name-input",
        "email-label",
        "email-input",
        "message-label",
        "message-input",
        "submit-button"
      ]
    },
    "name-label": {
      "type": "Label",
      "props": {
        "content": "Name"
      },
      "children": []
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your name",
        "type": "text"
      },
      "children": []
    },
    "email-label": {
      "type": "Label",
      "props": {
        "content": "Email"
      },
      "children": []
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      },
      "children": []
    },
    "message-label": {
      "type": "Label",
      "props": {
        "content": "Address"
      },
      "children": []
    },
    "message-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your address",
        "type": "text"
      },
      "children": []
    },
    "submit-button": {
      "type": "Button",
      "props": {
        "label": "Submit"
      },
      "on": {
        "press": {
          "action": "trackPress",
          "params": {
            "id": "submit-button",
            "label": "Submit"
          }
        }
      },
      "children": []
    }
  }
}