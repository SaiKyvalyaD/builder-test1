{
  "root": "contact-form",
  "elements": {
    "contact-form": {
      "type": "Card",
      "props": {
        "title": "Contact Form"
      },
      "children": [
        "name-label",
        "name-input",
        "email-label",
        "email-input",
        "btn",
        "cancel-btn"
      ]
    },
    "name-label": {
      "type": "Label",
      "props": {
        "content": "Name"
      },
      "children": []
    },
    "name-input": {
      "type": "Input",
      "props": {
        "placeholder": "Your name",
        "value": {
          "$bindState": "/contact/name"
        }
      },
      "children": []
    },
    "email-label": {
      "type": "Label",
      "props": {
        "content": "Email"
      },
      "children": []
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Email",
        "type": "email",
        "value": {
          "$bindState": "/contact/email"
        }
      },
      "children": []
    },
    "btn": {
      "type": "Button",
      "props": {
        "label": "Submit"
      },
      "children": []
    },
    "cancel-btn": {
      "type": "Button",
      "props": {
        "label": "Cancel",
        "variant": "destructive"
      },
      "children": []
    }
  }
}