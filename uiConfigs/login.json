{
  "root": "login-screen",
  "elements": {
    "login-screen": {
      "type": "Card",
      "props": {
        "title": "Login"
      },
      "children": [
        "form-stack"
      ]
    },
    "form-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 16
      },
      "children": [
        "username-label",
        "username-input",
        "password-label",
        "password-input",
        "login-button"
      ]
    },
    "username-label": {
      "type": "Label",
      "props": {
        "content": "Username"
      },
      "children": []
    },
    "username-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your username"
      },
      "on": {
        "change": {
          "action": "setState",
          "params": {
            "statePath": "/login/username",
            "value": {
              "$state": "/login/username"
            }
          }
        }
      },
      "children": []
    },
    "password-label": {
      "type": "Label",
      "props": {
        "content": "Password"
      },
      "children": []
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your password",
        "type": "password"
      },
      "on": {
        "change": {
          "action": "setState",
          "params": {
            "statePath": "/login/password",
            "value": {
              "$state": "/login/password"
            }
          }
        }
      },
      "children": []
    },
    "login-button": {
      "type": "Button",
      "props": {
        "label": "Login"
      },
      "on": {
        "press": {
          "action": "setState",
          "params": {
            "statePath": "/login/submitted",
            "value": true
          }
        }
      },
      "children": []
    }
  }
}