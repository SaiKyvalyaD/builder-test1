{
  "root": "login-form",
  "elements": {
    "login-form": {
      "type": "Card",
      "props": {
        "title": "Login"
      },
      "children": [
        "email-label",
        "email-input",
        "password-label",
        "password-input",
        "login-button"
      ]
    },
    "email-label": {
      "type": "Label",
      "props": {
        "content": "Email"
      },
      "children": []
    },
    "email-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your email",
        "type": "email"
      },
      "on": {
        "change": {
          "action": "setState",
          "params": {
            "statePath": "/form/email",
            "value": {
              "$state": "/form/email"
            }
          }
        }
      },
      "children": []
    },
    "password-label": {
      "type": "Label",
      "props": {
        "content": "Password"
      },
      "children": []
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your password",
        "type": "password"
      },
      "on": {
        "change": {
          "action": "setState",
          "params": {
            "statePath": "/form/password",
            "value": {
              "$state": "/form/password"
            }
          }
        }
      },
      "children": []
    },
    "login-button": {
      "type": "Button",
      "props": {
        "label": "Login",
        "variant": "default"
      },
      "on": {
        "press": {
          "action": "setState",
          "params": {
            "statePath": "/form/loggedIn",
            "value": true
          }
        }
      },
      "children": []
    }
  }
}