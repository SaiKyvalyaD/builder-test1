{
  "root": "login-form",
  "elements": {
    "login-form": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 10
      },
      "children": [
        "username-label",
        "username-input",
        "password-label",
        "password-input",
        "login-button"
      ]
    },
    "username-label": {
      "type": "Label",
      "props": {
        "content": "Username"
      },
      "children": []
    },
    "username-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your username",
        "type": "text"
      },
      "children": []
    },
    "password-label": {
      "type": "Label",
      "props": {
        "content": "Password"
      },
      "children": []
    },
    "password-input": {
      "type": "Input",
      "props": {
        "placeholder": "Enter your password",
        "type": "password"
      },
      "children": []
    },
    "login-button": {
      "type": "Button",
      "props": {
        "label": "Login"
      },
      "on": {
        "press": {
          "action": "trackPress",
          "params": {
            "id": "login-button",
            "label": "Login"
          }
        }
      },
      "children": []
    }
  }
}